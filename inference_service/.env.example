########## Common Variables ##########

# Environment
GE_ENVIRONMENT=local

# GCP Configuration
GE_GCP_PROJECT_ID=greenearth-471522
GE_GCP_REGION=us-east1

########## Inference Service Variables ##########

# ClearML Configuration (read by ClearML SDK)
CLEARML_WEB_HOST=https://app.clear.ml
CLEARML_API_HOST=https://api.clear.ml
CLEARML_API_ACCESS_KEY=api-access-key
CLEARML_API_SECRET_KEY=api-secret-key

# Model selection (choose one). To use ClearML, specify the ClearML model ID.
# Alternatively, specify a local path inside the container or a GCS URI.
GE_INFERENCE_CLEARML_MODEL_ID=clearml-model-id
# GE_INFERENCE_MODEL_URI=gs://your-bucket/path/to/model.pt
# GE_INFERENCE_MODEL_PATH=/path/inside/container/model.pt

# Inference service API configuration:
GE_INFERENCE_MAX_BATCH=1024
GE_INFERENCE_PREFER_CUDA=1
GE_INFERENCE_WARMUP=1
GE_INFERENCE_WARMUP_SECONDS_BUDGET=5.0
# Set this if you know the embedding dimension D in advance; it will be used for input validation and to create dummy warmup inputs.
GE_INFERENCE_INPUT_DIM=384
# Optional cache location inside container when using MODEL_URI=gs://...
GE_INFERENCE_MODEL_CACHE_DIR=/tmp/model_cache

# If your ClearML model artifacts are stored in GCS (e.g. `gs://...` URIs), ClearML will use
# Application Default Credentials. On Cloud Run/GKE this usually comes from the attached
# service account; for local runs you can mount a service account JSON and set:
GOOGLE_APPLICATION_CREDENTIALS=/path/to/sa.json
