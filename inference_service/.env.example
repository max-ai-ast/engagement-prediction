########## Common Variables ##########

# Environment
export GE_ENVIRONMENT=local

# GCP Configuration
export GE_GCP_PROJECT_ID=greenearth-471522
export GE_GCP_REGION=us-east1

# Domain mapping / DNS configuration (stage/prod)
export GE_ENABLE_INFERENCE_DOMAIN_MAPPING=true
# Defaults by environment if unset:
#   stage -> inference-stage.greenearth.social
#   prod  -> inference.greenearth.social
export GE_INFERENCE_DOMAIN=

########## Inference Service Variables ##########

# Model registry
# Configure which models to load (max 2), and provide a source for each model.
export GE_INFERENCE_MODELS="user-tower,post-tower"

# User tower model source (choose one)
# export GE_INFERENCE_USER_TOWER_MODEL_PATH=/path/inside/container/engagement_user_tower.pt
# export GE_INFERENCE_USER_TOWER_MODEL_URI=gs://your-bucket/path/to/engagement_user_tower.pt
# export GE_INFERENCE_USER_TOWER_CLEARML_MODEL_ID=clearml-model-id

# Post tower model source (choose one)
# export GE_INFERENCE_POST_TOWER_MODEL_PATH=/path/inside/container/engagement_post_tower.pt
# export GE_INFERENCE_POST_TOWER_MODEL_URI=gs://your-bucket/path/to/engagement_post_tower.pt
# export GE_INFERENCE_POST_TOWER_CLEARML_MODEL_ID=clearml-model-id

# Inference service API configuration:
export GE_INFERENCE_MAX_BATCH=1024
export GE_INFERENCE_PREFER_CUDA=1
export GE_INFERENCE_WARMUP=1
# Set this if you know the embedding dimension D in advance; it will be used for input validation and to create dummy warmup inputs.
export GE_INFERENCE_EMBED_DIM=384
# This is a required field. All histories shorter than this should be zero-padded to this length
export GE_INFERENCE_MAX_HISTORY_LEN=128

# Optional cache location inside container when using MODEL_URI=gs://...
export GE_INFERENCE_MODEL_CACHE_DIR=/tmp/model_cache
